#include <stdio.h>
#include <stdlib.h>
#include <time.h>

/* Global counters */
long long comparisons = 0;
long long swaps = 0;

/* Find the index of the minimum element that is not yet used */
int findMinIndex(int arr[], int n, int used[]) {
    int minIndex = -1;
    int i;
    for (i = 0; i < n; i++) {
        if (!used[i]) {
            if (minIndex == -1) {
                minIndex = i;
            } else {
                comparisons++;
                if (arr[i] < arr[minIndex]) {
                    minIndex = i;
                }
            }
        }
    }
    return minIndex;
}

/* Tournament Sort Function */
void tournamentSort(int arr[], int n) {
    int i;
    int *sorted = (int *)malloc(n * sizeof(int));
    int *used = (int *)calloc(n, sizeof(int)); /* 0 = unused, 1 = used */

    for (i = 0; i < n; i++) {
        int minIndex = findMinIndex(arr, n, used);
        swaps++; /* Count placement as a swap */
        sorted[i] = arr[minIndex];
        used[minIndex] = 1; /* Mark as used */
    }

    for (i = 0; i < n; i++) {
        arr[i] = sorted[i];
    }

    free(sorted);
    free(used);
}

/* Print an array */
void printArray(int arr[], int n) {
    int i;
    for (i = 0; i < n; i++)
        printf("%d ", arr[i]);
    printf("\n");
}

/* Main Program */
int main() {
    int choice, n, i;
    int *arr;

    printf("Tournament Sort Program\n");
    printf("1. Enter numbers manually\n");
    printf("2. Generate random numbers automatically\n");
    printf("Choose option (1 or 2): ");
    scanf("%d", &choice);

    if (choice == 1) {
        printf("How many numbers do you want to sort? ");
        scanf("%d", &n);
        arr = (int *)malloc(n * sizeof(int));
        if (!arr) {
            printf("Memory allocation failed!\n");
            return 1;
        }

        printf("Enter %d numbers:\n", n);
        for (i = 0; i < n; i++) {
            scanf("%d", &arr[i]);
        }

    } else if (choice == 2) {
        printf("How many numbers to generate? ");
        scanf("%d", &n);
        arr = (int *)malloc(n * sizeof(int));
        if (!arr) {
            printf("Memory allocation failed!\n");
            return 1;
        }

        srand(time(NULL));
        for (i = 0; i < n; i++) {
            arr[i] = rand() % 1000000; /* numbers between 0 and 999,999 */
        }

        printf("Generated numbers (first 20 shown if large):\n");
        for (i = 0; i < (n < 20 ? n : 20); i++)
            printf("%d ", arr[i]);
        if (n > 20) printf("...");
        printf("\n");

    } else {
        printf("Invalid option!\n");
        return 1;
    }

    clock_t start = clock();
    tournamentSort(arr, n);
    clock_t end = clock();

    printf("\nSorted array (first 20 shown if large):\n");
    for (i = 0; i < (n < 20 ? n : 20); i++)
        printf("%d ", arr[i]);
    if (n > 20) printf("...");
    printf("\n");

    printf("\nTotal comparisons: %lld\n", comparisons);
    printf("Total swaps:       %lld\n", swaps);
    printf("Time taken: %.2f seconds\n", (double)(end - start)/CLOCKS_PER_SEC);

    free(arr);
    return 0;
}
